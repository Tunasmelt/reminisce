# ─────────────────────────────────────────────────────────────────
# Reminisce v2 — Environment Variables Reference
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────────────

# ── Supabase (required) ──────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── App URL (required) ───────────────────────────────────────────
# Local:      http://localhost:3000
# Production: https://your-app.vercel.app  (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── BYOK Encryption (required) ───────────────────────────────────
# Must be exactly 32 characters for AES-256-GCM
# Generate: openssl rand -base64 24
ENCRYPTION_SECRET=your-32-character-secret-here

# ── Free Tier AI Providers ───────────────────────────────────────
# These providers absorb costs — users spend coins, not money
GROQ_API_KEY=gsk_your-groq-key                   # required for free tier
CEREBRAS_API_KEY=your-cerebras-key
SAMBANOVA_API_KEY=your-sambanova-key
GEMINI_API_KEY=your-gemini-key
MISTRAL_API_KEY=your-mistral-key
KIMI_API_KEY=your-kimi-key

# ── Pro Tier AI Providers ────────────────────────────────────────
# These providers are billed per-call — users spend gems
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
OPENAI_API_KEY=sk-your-openai-key

# ── OpenRouter (multi-provider fallback) ─────────────────────────
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key

# ── Legacy / backward compat ─────────────────────────────────────
MINIMAX_API_KEY=your-minimax-key

# ── Stripe Payments ──────────────────────────────────────────────
# Use sk_test_ and price_test_ during development
STRIPE_SECRET_KEY=sk_live_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-signing-secret
STRIPE_PRO_PRICE_ID=price_your-pro-monthly-price-id

# ─────────────────────────────────────────────────────────────────
# After filling in, run: npm run dev
# For production deploy, see DEPLOYMENT.md
# ─────────────────────────────────────────────────────────────────
