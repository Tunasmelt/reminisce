NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
ENCRYPTION_SECRET=your-32-char-secret-here

# ── Free Tier Providers (provider absorbs cost) ──────
GROQ_API_KEY=your-groq-key-here
CEREBRAS_API_KEY=your-cerebras-key-here
SAMBANOVA_API_KEY=your-sambanova-key-here
GEMINI_API_KEY=your-gemini-key-here
MISTRAL_API_KEY=your-mistral-key-here
KIMI_API_KEY=your-kimi-key-here

# ── Pro Tier Providers (billed via gems) ─────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENAI_API_KEY=your-openai-key-here

# ── OpenRouter (emergency fallback) ──────────────────
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_ENABLED=true

# ── Legacy (kept for backward compat) ────────────────
MINIMAX_API_KEY=your-minimax-key-here

# ── Stripe (required for payments) ───────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_your-stripe-secret-key-here
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-signing-secret-here
STRIPE_PRO_PRICE_ID=price_your-pro-plan-price-id-here

